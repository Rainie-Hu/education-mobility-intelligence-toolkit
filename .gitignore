# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
eggs/
*.egg

# Virtual environments
venv/
env/
.venv/
.env

# IDE
.vscode/
.idea/
*.swp
*.swo

# Jupyter
.ipynb_checkpoints/

# Data files (large raw data should not be committed)
data/raw/*.csv
data/raw/*.xlsx
data/raw/*.json
data/raw/*.xml
!data/raw/.gitkeep

# Processed data
data/processed/*.csv
data/processed/*.parquet
!data/processed/.gitkeep

# Generated reports
reports/*.pdf
reports/*.html
!reports/.gitkeep

# Environment variables
.env
.env.local

# OS files
.DS_Store
Thumbs.db

# Test coverage
htmlcov/
.coverage
.coverage.*
coverage.xml

# Distribution
*.tar.gz
*.whl
